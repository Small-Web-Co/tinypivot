{
  "name": "tinypivot-monorepo",
  "type": "module",
  "version": "1.0.83",
  "private": true,
  "packageManager": "pnpm@10.34.3",
  "description": "TinyPivot - Lightweight React & Vue data grid with free pivot tables, Pro charts, and optional AI Data Analyst.",
  "author": "Small Web, LLC",
  "license": "SEE LICENSE IN LICENSE.md",
  "homepage": "https://github.com/Small-Web-Co/tinypivot",
  "repository": {
    "type": "git",
    "url": "https://github.com/Small-Web-Co/tinypivot.git"
  },
  "bugs": {
    "url": "https://github.com/Small-Web-Co/tinypivot/issues"
  },
  "keywords": [
    "embedded-ai-data-analyst",
    "ai-enabled-data-grid",
    "ai-data-analyst",
    "conversational-analytics",
    "natural-language-query",
    "text-to-sql",
    "llm-data-analysis",
    "byok",
    "bring-your-own-key",
    "ai-data-exploration",
    "embedded-analytics",
    "conversational-bi",
    "self-service-analytics",
    "vue",
    "vue3",
    "react",
    "datagrid",
    "data-grid",
    "pivot-table",
    "pivot",
    "table",
    "grid",
    "excel",
    "spreadsheet",
    "data-table",
    "ag-grid-alternative",
    "tanstack-table",
    "filtering",
    "sorting",
    "aggregation",
    "csv-export",
    "chart-builder",
    "lightweight"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "pnpm run -r --parallel dev",
    "build": "pnpm run build:core && pnpm run build:server && pnpm run build:vue && pnpm run build:react",
    "build:core": "pnpm --filter @smallwebco/tinypivot-core build",
    "build:server": "pnpm --filter @smallwebco/tinypivot-server build",
    "build:vue": "pnpm --filter @smallwebco/tinypivot-vue build",
    "build:react": "pnpm --filter @smallwebco/tinypivot-react build",
    "demo": "vite --config vite.demo.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts && node scripts/prerender.mjs",
    "type-check": "pnpm run -r type-check",
    "clean": "rm -rf packages/*/dist node_modules/.cache coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "release:core": "cd packages/core && pnpm publish --access public --no-git-checks",
    "release:server": "cd packages/server && pnpm publish --access public --no-git-checks",
    "release:vue": "cd packages/vue && pnpm publish --access public --no-git-checks",
    "release:react": "cd packages/react && pnpm publish --access public --no-git-checks",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js patch",
    "release:minor": "node scripts/release.js minor",
    "release:major": "node scripts/release.js major",
    "prepare": "husky"
  },
  "dependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev13.0",
    "@tanstack/vue-table": "^8.21.3",
    "@vercel/analytics": "^1.6.1",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/node": "^20.19.41",
    "@vercel/node": "^5.8.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^3.2.6",
    "@vue/server-renderer": "^3.5.38",
    "@vue/test-utils": "^2.4.10",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.14",
    "stripe": "^22.1.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.3.3",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^3.2.6",
    "vue": "^3.5.34",
    "vue-tsc": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,ts,vue,mjs,tsx}": "eslint --fix"
  }
}
